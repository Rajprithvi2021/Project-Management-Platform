{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": ".",
  "testMatch": ["<rootDir>/tests/**/*.test.ts"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": { "strict": false, "types": ["jest", "node"] } }]
  },
  "testTimeout": 30000,
  "forceExit": true,
  "detectOpenHandles": false
}
